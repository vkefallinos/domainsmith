  ],
  "tasks": [
    {
      "flowId": "generate-care-plan",
      "order": 1,
      "name": "Create Plant Snapshot",
      "description": "Summarize current plant context and risk signals",
      "type": "updateFlowOutput",
      "config": {
        "model": "claude-3-5-sonnet",
        "temperature": 0.2,
        "taskInstructions": "Create a concise status snapshot from profile and symptom inputs.",
        "outputSchema": {
          "type": "object",
          "properties": {
            "plantType": {
              "type": "string"
            },
            "growthStage": {
              "type": "string"
            },
            "riskLevel": {
              "type": "string",
              "enum": [
                "low",
                "medium",
                "high"
              ]
            }
          },
          "required": [
            "plantType",
            "growthStage",
            "riskLevel"
          ]
        },
        "targetFieldName": "snapshot"
      }
    },
    {
      "flowId": "generate-care-plan",
      "order": 2,
      "name": "Generate Weekly Actions",
      "description": "Create practical daily/weekly tasks",
      "type": "updateFlowOutput",
      "config": {
        "isPushable": false,
        "model": "claude-3-5-sonnet",
        "temperature": 0.3,
        "taskInstructions": "Generate a safe, low-maintenance one-week action list.",
        "outputSchema": {
          "type": "object",
          "properties": {
            "actions": {
              "type": "array",
              "items": {
                "type": "object",
                "properties": {
                  "day": {
                    "type": "string"
                  },
                  "task": {
                    "type": "string"
                  },
                  "reason": {
                    "type": "string"
                  }
                },
                "required": [
                  "day",
                  "task"
                ]
              }
            }
          },
          "required": [
            "actions"
          ]
        },
        "targetFieldName": "weeklyActions"
      }
    },
    {
      "flowId": "generate-care-plan",
      "order": 3,
      "name": "Recommend Follow up Check",
      "description": "Provide a follow-up checkpoint for symptom re-evaluation",
      "type": "executeTask",
      "config": {
        "enabledTools": [
          "plant-care-scheduler",
          "disease-symptom-checker"
        ],
        "model": "claude-3-5-sonnet",
        "temperature": 0.2,
        "taskInstructions": "Suggest when the user should reassess and what to observe."
      }
    }
  ]
